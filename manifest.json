{
  "manifest_version": 3,
  "name": "万象取存 OmniFetch",
  "version": "3.0",
  "description": "一键嗅探并下载网页图片与视频素材（支持自动检测）。本工具仅供个人学习与研究使用。",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "omnifetch@kevin-wenkai.github.io",
      "strict_min_version": "109.0",
      "data_collection_permissions": {}
    }
  },
  
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "万象取存 OmniFetch"
  },
  
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],
  
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  
  "privacy_policy_url": "https://kevin-wenkai.github.io/material-downloader-privacy/"
}
